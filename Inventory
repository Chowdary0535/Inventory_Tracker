<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventory Tracker</title>
<link rel="stylesheet" href="style.css">
</head>
<body>
<div class="container">
    <header>
        <h1>📦 Inventory Tracker</h1>
        <p class="subtitle">Node.js + Express + MySQL</p>
    </header>

    <section class="card form-card">
        <h2 id="form-title">Add New Item</h2>
        <form id="item-form">
            <input type="hidden" id="item-id">
            <div class="form-row">
                <div class="form-group">
                    <label for="name">Item Name</label>
                    <input type="text" id="name" required placeholder="e.g. Wireless Mouse">
                </div>
                <div class="form-group">
                    <label for="category">Category</label>
                    <input type="text" id="category" placeholder="e.g. Electronics">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="quantity">Quantity</label>
                    <input type="number" id="quantity" min="0" required placeholder="0">
                </div>
                <div class="form-group">
                    <label for="price">Price (₹)</label>
                    <input type="number" id="price" min="0" step="0.01" required placeholder="0.00">
                </div>
                <div class="form-group">
                    <label for="supplier">Supplier</label>
                    <input type="text" id="supplier" placeholder="e.g. Logitech India">
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" id="submit-btn">Add Item</button>
                <button type="button" id="cancel-btn" class="hidden">Cancel</button>
            </div>
        </form>
    </section>

    <section class="card">
        <div class="table-header">
            <h2>Current Inventory</h2>
            <input type="text" id="search" placeholder="🔍 Search items...">
        </div>
        <div class="table-wrapper">
            <table id="items-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Supplier</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="items-body">
                </tbody>
            </table>
        </div>
        <p id="empty-state" class="hidden">No items found. Add your first item above.</p>
    </section>

    <div id="toast" class="toast hidden"></div>
</div>

<script src="script.js"></script>
</body>
</html>
